# Volcengine TOS (object storage)
TOS_ACCESS_KEY=your-tos-access-key
TOS_SECRET_KEY=your-tos-secret-key
TOS_BUCKET=your-bucket-name
TOS_REGION=cn-shanghai
TOS_ENDPOINT=tos-cn-shanghai.volces.com

# Volcengine Ark (video: Seedance; image: Seedream; LLM: Doubao)
ARK_API_KEY=your-ark-api-key

# Model selection — the server automatically picks fast/standard/pro based on
# the project's requested resolution. Override per tier if your account has
# different model IDs available.
SEEDANCE_FAST=doubao-seedance-2-0-fast-260128
SEEDANCE_STD=doubao-seedance-2-0-260128
SEEDANCE_PRO=doubao-seedance-2-0-pro-260215
SEEDREAM_MODEL=doubao-seedream-4-5-251128
LLM_MODEL=doubao-1-5-lite-32k-250115

# HTTP Basic Auth (required)
AUTH_USER=your-username
AUTH_PASS=your-strong-password
